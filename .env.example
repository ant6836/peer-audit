# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 git에 올라가지 않음)
# Vercel 배포 시에는 대시보드 > Settings > Environment Variables 에 동일하게 등록.

# ── LLM (OpenRouter, OpenAI 호환) ──
LLM_API_KEY=sk-or-v1-...            # https://openrouter.ai/keys 에서 발급
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3.5-flash-02-23   # 사용할 모델 (OpenRouter 모델 slug)

# (선택) OpenRouter 랭킹/식별용 헤더
# LLM_SITE_URL=https://your-app.vercel.app
# LLM_SITE_NAME=동종기업 분석

# ── DART (임의 상장사 라이브 주석 조회에 필요) ──
# 설정 시: 6개 쇼케이스 외 임의 상장사도 DART에서 실시간으로 연결주석을 가져옴.
# 미설정 시: 번들 픽스처(6개사)만 동작.
# 로컬은 사내망 TLS로 DART 직접호출이 막혀 보통 비워둠(픽스처로 검증). Vercel에 등록해 사용.
DART_API_KEY=...                    # https://opendart.fss.or.kr 에서 발급
